    <style>
        /* BASE & VARIABLES DE DISEÑO (Paleta Creativa/Premium) */
        :root {
            --primary: #0f172a;       /* Azul pizarra profundo (Sofisticación) */
            --secondary: #2563eb;     /* Azul eléctrico (Innovación/Creatividad) */
            --accent: #06b6d4;        /* Turquesa vibrante (Acento moderno) */
            --text-main: #334155;     /* Gris oscuro para lectura óptima */
            --text-light: #64748b;    /* Gris medio para subtítulos */
            --bg-light: #f8fafc;      /* Fondo suave */
            --border-color: #e2e8f0;  /* Líneas sutiles */
        }

        @page {
            size: A4;
            margin: 15mm 15mm 15mm 15mm;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text-main);
            background-color: #ffffff;
            line-height: 1.6;
            font-size: 11pt;
            padding: 30px;
        }

        /* DISEÑO DE LA CABECERA CON FOTO */
        .header-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid var(--primary);
            padding-bottom: 25px;
            margin-bottom: 30px;
            gap: 20px;
        }

        .header-profile-box {
            display: flex;
            align-items: center;
            gap: 25px;
        }

        .profile-photo-container {
            width: 110px;
            height: 110px;
            border-radius: 50%;
            overflow: hidden;
            border: 3px solid var(--secondary);
            background-color: var(--bg-light);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .profile-photo-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .header-title-box h1 {
            font-size: 28pt;
            font-weight: 800;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: -0.5px;
            line-height: 1.1;
        }

        .header-title-box .tagline {
            font-size: 13pt;
            color: var(--secondary);
            font-weight: 600;
            margin-top: 5px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .contact-sidebar {
            text-align: right;
            font-size: 9.5pt;
            color: var(--text-light);
            list-style: none;
            flex-shrink: 0;
        }

        .contact-sidebar li {
            margin-bottom: 4px;
        }

        /* EXTRACTO / PERFIL DE ALTO IMPACTO */
        .profile-summary {
            background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
            border-left: 5px solid var(--secondary);
            padding: 20px;
            border-radius: 4px;
            margin-bottom: 35px;
        }

        .profile-summary p {
            font-size: 11.5pt;
            text-align: justify;
            color: var(--primary);
        }

        /* SECCIONES PRINCIPALES */
        h2 {
            font-size: 14pt;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            page-break-after: avoid;
        }

        h2::after {
            content: '';
            flex: 1;
            height: 1px;
            background-color: var(--border-color);
            margin-left: 15px;
        }

        /* CRONOLOGÍA (Educación y Proyectos) */
        .timeline-item {
            margin-bottom: 25px;
            page-break-inside: avoid;
        }

        .timeline-header {
            display: flex;
            justify-content: space-between;
            font-size: 11pt;
            margin-bottom: 5px;
        }

        .institution-title {
            font-weight: 700;
            color: var(--primary);
        }

        .timeline-date {
            font-weight: 600;
            color: var(--secondary);
            font-style: italic;
        }

        .degree-subtitle {
            font-style: italic;
            color: var(--text-light);
            font-size: 10pt;
            margin-bottom: 8px;
        }

        ul {
            padding-left: 20px;
            margin-bottom: 15px;
        }

        li {
            margin-bottom: 6px;
            text-align: justify;
        }

        .highlight {
            font-weight: 600;
            color: var(--secondary);
        }

        /* MATRIZ DE COMPETENCIAS (Estilo Dashboard Creativo) */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 35px;
            page-break-inside: avoid;
        }

        .skills-card {
            background-color: var(--bg-light);
            border: 1px solid var(--border-color);
            padding: 15px;
            border-radius: 6px;
        }

        .skills-card h3 {
            font-size: 11pt;
            color: var(--primary);
            margin-bottom: 12px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 5px;
        }

        .badge-container {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .badge {
            background-color: #ffffff;
            color: var(--primary);
            border: 1px solid #cbd5e1;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 9pt;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .badge-soft {
            background-color: #eff6ff;
            color: var(--secondary);
            border: 1px solid #bfdbfe;
        }

        /* PROYECTOS E INVESTIGACIONES */
        .project-box {
            border-left: 3px solid var(--accent);
            padding-left: 15px;
            margin-bottom: 20px;
            page-break-inside: avoid;
        }

        .footer-note {
            margin-top: 40px;
            font-size: 8.5pt;
            color: var(--text-light);
            text-align: center;
            border-top: 1px dashed var(--border-color);
            padding-top: 15px;
            page-break-inside: avoid;
        }
    </style>
</head>
